---
interface Props {
  title: string;
  accent?: string;
}

const { title, accent = 'var(--gold)' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — KoreaIn</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&family=Noto+Serif+KR:wght@300;400;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <style define:vars={{ accent }}>
      :root { --branch-accent: var(--accent); }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>